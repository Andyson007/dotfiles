[init]
  defaultBranch = "main"

[user]
  name = Andy
  email = andreas.jan.van.der.meulen@gmail.com
[core]
  pager = delta

[interactive]
  diffFilter = delta --color-only

[delta]
  navigate = true  # use n and N to move between diff sections
  dark = true      # or light = true, or omit for auto-detection
  line-numbers = true

[merge]
    conflictStyle = zdiff3
[alias]
c = "commit"
st = "status"
a = "add"
